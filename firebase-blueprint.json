{
  "entities": {
    "users": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email", "role"]
    },
    "videos": {
      "title": "Video",
      "description": "Video content information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "url": { "type": "string" },
        "thumbnail": { "type": "string" },
        "type": { "type": "string", "enum": ["hls", "mp4"] },
        "category": { "type": "string" },
        "cast": { "type": "string" },
        "description": { "type": "string" },
        "year": { "type": "string" },
        "addedBy": { "type": "string", "description": "UID of the user who added the video" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "url", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profiles"
    },
    "/videos/{videoId}": {
      "schema": "videos",
      "description": "Global video library"
    }
  }
}

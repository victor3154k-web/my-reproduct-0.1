rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, email format)
    //   - role: string (required, 'admin' or 'user')
    //   - createdAt: timestamp (optional)
    //
    // Collection: videos
    // Document ID: {videoId}
    // Fields:
    //   - id: string (required)
    //   - title: string (required)
    //   - url: string (required)
    //   - thumbnail: string (optional)
    //   - type: string (required, 'hls' or 'mp4')
    //   - category: string (optional)
    //   - cast: string (optional)
    //   - description: string (optional)
    //   - year: string (optional)
    //   - addedBy: string (optional)
    //   - createdAt: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "victor3154k@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'];
    }

    function isValidVideo(data) {
      return data.keys().hasAll(['id', 'title', 'url', 'type']) &&
             data.id is string &&
             data.title is string &&
             data.url is string &&
             data.type in ['hls', 'mp4'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role && isValidUser(request.resource.data)));
      allow delete: if isAdmin();
    }

    match /videos/{videoId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidVideo(request.resource.data);
      allow update: if isAuthenticated() && (isAdmin() || request.resource.data.addedBy == request.auth.uid);
      allow delete: if isAdmin();
    }
  }
}
